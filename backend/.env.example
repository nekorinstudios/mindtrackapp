# =============================================================================
# MindTrack Journey — Backend Environment Template
# =============================================================================
# Copy this file to `.env` and fill in the real values for your environment.
#
#   cp backend/.env.example backend/.env
#
# Never commit backend/.env — it contains secrets. The real values in
# production are set in the Render dashboard (see RENDER_DEPLOY.md).
# -----------------------------------------------------------------------------


# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------

# MongoDB connection string.
# Local dev example: mongodb://localhost:27017
# MongoDB Atlas:     mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/mindtrack?retryWrites=true&w=majority
MONGO_URL=mongodb://localhost:27017

# Name of the database inside your MongoDB instance.
DB_NAME=mindtrack


# -----------------------------------------------------------------------------
# Authentication
# -----------------------------------------------------------------------------

# Secret used to sign JWT access tokens. Must be a long random string.
# Generate one with: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=change-me-to-a-long-random-string


# -----------------------------------------------------------------------------
# Admin bootstrap
# -----------------------------------------------------------------------------
# An admin user with these credentials is created (or updated) on every
# backend startup. Admins bypass onboarding and the paywall.

# Admin email — this is the login identifier.
ADMIN_EMAIL=admin@mindtrackjourney.com

# Admin password — must be strong. This value is hashed with bcrypt before
# being stored; the plaintext is only read at startup and never logged.
ADMIN_PASSWORD=change-me-strong-admin-password

# Admin username (displayed in the app; can differ from email).
ADMIN_USERNAME=admin


# -----------------------------------------------------------------------------
# Stripe (payments)
# -----------------------------------------------------------------------------
# Required for the $1.99/month subscription paywall. Leave blank locally
# if you're only working on features that don't touch billing.

# Restricted API key from Stripe → Developers → API keys.
# Format: rk_live_... (production) or rk_test_... (test mode).
STRIPE_SECRET_KEY=

# Payment Link URL — Stripe → Products → your subscription → Payment link.
# Format: https://buy.stripe.com/...
STRIPE_PAYMENT_LINK=

# Webhook signing secret from Stripe → Developers → Webhooks → your endpoint.
# Used to verify that incoming webhook events are actually from Stripe.
# Format: whsec_...
STRIPE_WEBHOOK_SECRET=

# Price displayed in the paywall UI (used for messaging only — Stripe still
# controls the actual charge based on the Payment Link).
SUBSCRIPTION_PRICE_USD=1.99

# Number of free trial days before the first charge.
SUBSCRIPTION_TRIAL_DAYS=7


# -----------------------------------------------------------------------------
# Email (Resend)
# -----------------------------------------------------------------------------
# Optional for local dev. Without these keys the app still works, but
# password reset emails, doctor reports, and email verification won't send.

# API key from https://resend.com/api-keys — format: re_...
RESEND_API_KEY=

# Sender address used in the "From:" header of outgoing emails.
# Use `onboarding@resend.dev` until you verify your own domain.
# After Resend verifies mindtrackjourney.com, switch to something like:
#   noreply@mindtrackjourney.com
SENDER_EMAIL=onboarding@resend.dev


# -----------------------------------------------------------------------------
# CORS (Cross-Origin Resource Sharing)
# -----------------------------------------------------------------------------
# Both are optional overrides — the code ships with sensible defaults
# covering production, local dev, and the Emergent preview subdomain.

# Extra allowed origins beyond the defaults. Comma-separated.
# Example: https://staging.mindtrackjourney.com,https://alt.mindtrackjourney.com
CORS_ORIGINS=

# Regex that origins can match. Leave blank to use the built-in default:
#   ^https://([a-zA-Z0-9-]+\.)*emergentagent\.com$
#   | ^https://([a-zA-Z0-9-]+\.)*mindtrackjourney\.com$
CORS_ORIGIN_REGEX=


# -----------------------------------------------------------------------------
# Backend base URL
# -----------------------------------------------------------------------------
# Public URL where THIS backend is reachable. Used to build Stripe
# checkout return URLs, email links, etc.
# Local dev: http://localhost:8001
# Production: https://api.mindtrackjourney.com
EXPO_PUBLIC_BACKEND_URL=http://localhost:8001
