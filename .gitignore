# =============================================================================
# .gitignore — MindTrack Journey (Expo frontend + FastAPI backend monorepo)
# =============================================================================
# Organized by section. Keep this file tidy — add new patterns under the
# section that best fits and preserve alphabetical order within a section.

# -----------------------------------------------------------------------------
# Node / JavaScript
# -----------------------------------------------------------------------------
node_modules/
/node_modules
.pnp
.pnp.js
.yarn/install-state.gz
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.tsbuildinfo

# -----------------------------------------------------------------------------
# Expo / React Native (frontend)
# -----------------------------------------------------------------------------
.expo/
web-build/
expo-env.d.ts
.metro-health-check*
app-example/

# Native build outputs from `eas build` local prebuild
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.mobileprovision
android/app/build/
android/build/
ios/build/
android-sdk/

# -----------------------------------------------------------------------------
# Python / FastAPI (backend)
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# Virtual environments
.venv/
venv/
env/
ENV/

# -----------------------------------------------------------------------------
# Python testing / typing / lint caches
# -----------------------------------------------------------------------------
.pytest_cache/
.mypy_cache/
.ruff_cache/
.tox/
.nox/
.hypothesis/

# -----------------------------------------------------------------------------
# Python coverage reports
# -----------------------------------------------------------------------------
.coverage
.coverage.*
htmlcov/
coverage.xml
*.cover
nosetests.xml

# -----------------------------------------------------------------------------
# Python build artifacts
# -----------------------------------------------------------------------------
build/
dist/
*.egg-info/
*.egg
__pypackages__/
pip-wheel-metadata/

# -----------------------------------------------------------------------------
# Environment files (secrets — NEVER commit)
# -----------------------------------------------------------------------------
.env
.env.*
backend/.env
backend/.env.*
frontend/.env
frontend/.env.*

# ...but always keep example templates tracked
!.env.example
!*.env.example
!backend/.env.example
!frontend/.env.example

# -----------------------------------------------------------------------------
# Credentials / keys
# -----------------------------------------------------------------------------
*token.json*
*credentials.json*
credentials.json
.credentials
*.pem
*.key
google-services.json
GoogleService-Info.plist

# -----------------------------------------------------------------------------
# IDEs / Editors
# -----------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*.sublime-*

# -----------------------------------------------------------------------------
# Operating system
# -----------------------------------------------------------------------------
.DS_Store
Thumbs.db
Desktop.ini

# -----------------------------------------------------------------------------
# Logs and temporary files
# -----------------------------------------------------------------------------
*.log
*.tmp
*.bak
*.old
dump.rdb

# -----------------------------------------------------------------------------
# Local artifacts (not for version control)
# -----------------------------------------------------------------------------
memory/test_credentials.md
.cache/
.ipynb_checkpoints/

# -----------------------------------------------------------------------------
# Large binaries / archives (avoid accidental commits)
# -----------------------------------------------------------------------------
**/*.zip
**/*.tar
**/*.tar.gz
**/*.tgz
*.pack
*.deb
*.dylib

# -----------------------------------------------------------------------------
# Deployment platforms (future-proofing; harmless if unused)
# -----------------------------------------------------------------------------
.vercel

# -----------------------------------------------------------------------------
# Chainlit / notebook artifacts (kept from Emergent template — safe to remove
# if you never touch these tools)
# -----------------------------------------------------------------------------
chainlit.md
.chainlit
.ac
